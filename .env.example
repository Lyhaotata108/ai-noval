# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_BASE_URL: Optional custom proxy/relay base URL for Gemini API (e.g. for bypassing regional restrictions).
# If left empty, default Google official endpoint will be used.
GEMINI_BASE_URL=""

# ==========================================
# 🌟 MULTI-PROVIDER AI CONFIGURATION (支持 ChatGPT / DeepSeek / 任何中转站)
# ==========================================
# LLM_PROVIDER: 选择 AI 提供商，可选值: gemini | openai | deepseek | custom (默认：gemini)
# 如果提供了 DEEPSEEK_API_KEY，系统将自动设为 deepseek；如果提供了 OPENAI_API_KEY，将自动设为 openai。
LLM_PROVIDER="gemini"

# LLM_API_KEY: 统一的第三方 API Key (如果是 OpenAI/DeepSeek，也可以直接设置下面的各自 Key)
LLM_API_KEY=""

# LLM_BASE_URL: 第三方 API 的中转站/代理基础 URL。例如：
# - DeepSeek 默认: "https://api.deepseek.com/v1"
# - OpenAI 默认: "https://api.openai.com/v1"
# - 任何 OpenAI 格式的自定义中转接口: "https://api.yourproxy.com/v1"
# 注意：路径最后的 /v1 建议带上，取决于中转站的要求
LLM_BASE_URL=""

# LLM_MODEL: 第三方模型名称。例如:
# - DeepSeek 默认: "deepseek-chat" (即 deepseek-v3) / 或者是 "deepseek-reasoner"
# - OpenAI 默认: "gpt-4o-mini" / 或者是 "gpt-4o", "gpt-3.5-turbo"
LLM_MODEL=""

# 各提供商的独立密钥，设置了这些即可自动启用
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
